<script type="module">
import mermaid from 'https://esm.sh/mermaid@11/dist/mermaid.esm.min.mjs';
await document.fonts.ready;
mermaid.initialize({
  startOnLoad: false,
  theme: 'base',
  fontFamily: 'sans-serif',
  themeVariables: {
    fontSize: '13px',
    lineColor: '#73726c',
    textColor: '#3d3d3a',
  },
});
const { svg } = await mermaid.render('erd-svg', `erDiagram
  USUARIO {
    uuid id PK
    string username
    string password_hash
    string rol
  }
  PACIENTE {
    uuid id PK
    uuid usuario_id FK
    string nombre
    string apellido
    date fecha_nacimiento
    string telefono
    string direccion
  }
  MEDICO {
    uuid id PK
    uuid usuario_id FK
    string nombre
    string apellido
    string especialidad
    string numero_colegiado
  }
  CITA {
    uuid id PK
    uuid paciente_id FK
    uuid medico_id FK
    datetime fecha_hora
    string estado
    string motivo
  }
  EXPEDIENTE {
    uuid id PK
    uuid paciente_id FK
    date fecha_creacion
    string antecedentes
  }
  CONSULTA {
    uuid id PK
    uuid expediente_id FK
    uuid medico_id FK
    datetime fecha
    string diagnostico
    string tratamiento
  }
  MEDICAMENTO {
    uuid id PK
    string nombre
    string descripcion
    string presentacion
  }
  PRESCRIPCION {
    uuid id PK
    uuid consulta_id FK
    uuid medicamento_id FK
    string dosis
    string frecuencia
    int duracion_dias
  }

  USUARIO ||--o| PACIENTE : "tiene perfil"
  USUARIO ||--o| MEDICO : "tiene perfil"
  PACIENTE ||--o{ CITA : "agenda"
  MEDICO ||--o{ CITA : "atiende"
  PACIENTE ||--|| EXPEDIENTE : "posee"
  EXPEDIENTE ||--o{ CONSULTA : "contiene"
  MEDICO ||--o{ CONSULTA : "realiza"
  CONSULTA ||--o{ PRESCRIPCION : "incluye"
  MEDICAMENTO ||--o{ PRESCRIPCION : "aparece en"
`);
document.getElementById('erd').innerHTML = svg;
</script>


</body></html>